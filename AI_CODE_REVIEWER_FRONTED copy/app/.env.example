# Frontend Environment Variables
# Copy this file to .env.local and update with your actual values

# API Service Endpoints
VITE_API_AUTH_URL=http://localhost:3001/api/auth
VITE_API_EDITOR_URL=http://localhost:3002
VITE_API_AI_URL=http://localhost:3003/api/ai
VITE_API_REPO_FIXER_URL=http://localhost:3004/api/repo
VITE_API_CODE_GEN_URL=http://localhost:3005/api

# WebSocket Endpoints
VITE_WS_EDITOR_URL=ws://localhost:3002/ws
VITE_WS_AI_URL=ws://localhost:3003/ws

# Frontend URL (for OAuth redirects)
VITE_FRONTEND_URL=http://localhost:5173

# GitHub OAuth Configuration (if using GitHub login)
VITE_GITHUB_CLIENT_ID=your_github_client_id_here
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback

# Other Configuration
VITE_APP_NAME=AI Code Reviewer
VITE_APP_VERSION=1.0.0
